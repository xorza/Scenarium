[
  {
    "label": "cargo test --release",
    "command": "cargo",
    "args": [
      "test",
      "-p",
      "$ZED_CUSTOM_RUST_PACKAGE",
      "--release",
      "$ZED_SYMBOL",
      "--",
      "--ignored",
      "--nocapture",
    ],
    "tags": ["rust-test"],
  },
  {
    "label": "run darkroom",
    "command": "cargo",
    "args": ["run", "-p", "darkroom"],
  },
  {
    "label": "run palantir showcase",
    "command": "cargo",
    "args": ["run", "--manifest-path", "palantir/Cargo.toml"],
  },
]
