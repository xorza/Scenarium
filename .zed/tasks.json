[
  {
    "label": "cargo test --release",
    "command": "cargo",
    "args": [
      "test",
      "-p",
      "$ZED_CUSTOM_RUST_PACKAGE",
      "--release",
      "$ZED_SYMBOL",
      "--",
      "--include-ignored",
      "--nocapture",
    ],
    "tags": ["rust-test"],
  },
  {
    "label": "run darkroom",
    "command": "cargo",
    "args": ["run", "-p", "darkroom"],
  },
  {
    "label": "run darkroom release with tracy",
    "command": "cargo",
    "args": [
      "run",
      "--release",
      "-p",
      "darkroom",
      "--features",
      "profile-with-tracy",
    ],
  },
  {
    "label": "run darkroom GUI (script TCP, no auth)",
    "command": "cargo",
    "args": [
      "run",
      "-p",
      "darkroom",
      "--",
      "--script-tcp",
      "--script-no-auth",
      "--script-bind",
      "127.0.0.1:34567",
      "gui",
    ],
  },
  {
    "label": "run palantir showcase",
    "command": "RUST_BACKTRACE=1 cargo",
    "args": ["run", "--release", "--manifest-path", "palantir/Cargo.toml"],
  },
  {
    "label": "run palantir showcase with tracy",
    "command": "RUST_BACKTRACE=1 cargo",
    "args": [
      "run",
      "--release",
      "--manifest-path",
      "palantir/Cargo.toml",
      "--features",
      "profile-with-tracy",
    ],
  },
]
