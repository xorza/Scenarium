  {
    "label": "run darkroom",
    "command": "cargo",
    "args": ["run", "-p", "darkroom"],
  },
  {
    "label": "run darkroom release with tracy",
    "command": "cargo",
    "args": [
      "run",
      "--release",
      "-p",
      "darkroom",
      "--features",
      "profile-with-tracy",
    ],
  },
  {
    "label": "run palantir showcase",
    "command": "RUST_BACKTRACE=1 cargo",
    "args": ["run", "--release", "--manifest-path", "palantir/Cargo.toml"],
  },
  {
    "label": "run palantir showcase with tracy",
    "command": "RUST_BACKTRACE=1 cargo",
    "args": [
      "run",
      "--release",
      "--manifest-path",
      "palantir/Cargo.toml",
      "--features",
      "profile-with-tracy",
    ],
  },
]
