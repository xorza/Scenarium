{
    "env": {
        "RUST_BACKTRACE": "1",
        "CARGO_TERM_COLOR": "always"
    },
    "permissions": {
        "defaultMode": "acceptEdits",
        "allow": [
            "WebSearch",
            "WebFetch",
            "WebFetch(*)",

            "Bash(cargo test:*)",
            "Bash(cargo nextest:*)",
            "Bash(cargo build:*)",
            "Bash(cargo run:*)",
            "Bash(cargo clippy:*)",
            "Bash(cargo fmt:*)",
            "Bash(cargo check:*)",
            "Bash(cargo bench *)",

            "Bash(perf annotate *)",
            "Bash(perf report *)",
            "Bash(perf record *)",
            "Bash(perf stat *)",
            "Bash(perf script *)",

            "Bash(readelf *)",
            "Bash(objdump *)",
            "Bash(nm *)",
            "Bash(addr2line *)",
            "Bash(delta *)",

            "Bash(rustc --version)",
            "Bash(rustup target *)",

            "Read(//proc/sys/kernel/**)",
            "Bash(mkdir -p .tmp)",
            "Bash(gh api *)",
            "Bash(awk *)"
        ],
        "deny": ["Read(./.env)"]
    },
    "sandbox": {
        "enabled": true,
        "autoAllowBashIfSandboxed": true
    }
}
